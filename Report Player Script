-- MINIMIZE LOGIC
local minimized = false

Minimize.MouseButton1Click:Connect(function()

    minimized = not minimized

    if minimized then
        Scroll.Visible = false
        TabBar.Visible = false
        Main.Size = UDim2.new(0,500,0,40)
        Minimize.Text = "+"
    else
        Scroll.Visible = true
        TabBar.Visible = true
        Main.Size = UDim2.new(0,500,0,380)
        Minimize.Text = "-"
    end

end)

-- CREATE MESSAGE
local function createMessage(text)

    local Frame = Instance.new("Frame")
    Frame.Parent = Scroll
    Frame.Size = UDim2.new(1,0,0,40)
    Frame.BackgroundColor3 = Color3.fromRGB(40,40,40)

    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,6)

    local Label = Instance.new("TextLabel")
    Label.Parent = Frame
    Label.Size = UDim2.new(0.75,0,1,0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.new(1,1,1)
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 13
    Label.TextWrapped = true

    local Copy = Instance.new("TextButton")
    Copy.Parent = Frame
    Copy.Size = UDim2.new(0.25,-5,0.7,0)
    Copy.Position = UDim2.new(0.75,5,0.15,0)
    Copy.Text = "Copy"
    Copy.BackgroundColor3 = Color3.fromRGB(60,60,60)
    Copy.TextColor3 = Color3.new(1,1,1)
    Copy.Font = Enum.Font.GothamBold
    Copy.TextSize = 13

    Instance.new("UICorner", Copy).CornerRadius = UDim.new(0,6)

    Copy.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(text)
            Copy.Text = "Copied"
            task.wait(1)
            Copy.Text = "Copy"
        end
    end)

end

-- CLEAR
local function clear()
    for _,v in pairs(Scroll:GetChildren()) do
        if v:IsA("Frame") then
            v:Destroy()
        end
    end
end

-- LOAD AVATAR
local function loadAvatar()

    clear()

    AvatarTab.BackgroundColor3 = Color3.fromRGB(60,60,60)
    CheatTab.BackgroundColor3 = Color3.fromRGB(35,35,35)

    createMessage("This avatar appears inappropriate for a kid-friendly experience.")
    createMessage("The avatar contains suspicious visual elements.")
    createMessage("This avatar may violate Roblox avatar rules.")
    createMessage("The avatar may create discomfort for other players.")
    createMessage("This avatar should be reviewed by moderation.")

end

-- LOAD CHEAT
local function loadCheat()

    clear()

    CheatTab.BackgroundColor3 = Color3.fromRGB(60,60,60)
    AvatarTab.BackgroundColor3 = Color3.fromRGB(35,35,35)

    createMessage("This player may be using exploits.")
    createMessage("This player shows abnormal movement.")
    createMessage("This player may be using third-party tools.")
    createMessage("This player is suspected of cheating.")
    createMessage("This player disrupts fair gameplay.")

end

AvatarTab.MouseButton1Click:Connect(loadAvatar)
CheatTab.MouseButton1Click:Connect(loadCheat)

loadAvatar()
